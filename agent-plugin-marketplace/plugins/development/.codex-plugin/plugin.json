{
  "name": "development",
  "version": "0.5.0",
  "description": "Codex CLI と Claude Code で共通利用する開発用 skills、tools、MCP servers。",
  "author": {
    "name": "mami0tsu"
  },
  "repository": "https://github.com/mami0tsu/dotfiles",
  "license": "MIT",
  "keywords": [
    "development",
    "mcp",
    "codex",
    "claude-code",
    "aws",
    "terraform",
    "github",
    "workflow"
  ],
  "skills": "./skills/",
  "mcpServers": {
    "aws": {
      "type": "stdio",
      "command": "uvx",
      "timeout": 100000,
      "args": [
        "mcp-proxy-for-aws==1.6.3",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--region",
        "ap-northeast-1"
      ]
    },
    "terraform": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server:1.1.0",
        "--toolsets=registry"
      ]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "bearer_token_env_var": "GITHUB_MCP_TOKEN"
    },
    "linear": {
      "type": "http",
      "url": "https://mcp.linear.app/mcp"
    }
  },
  "interface": {
    "displayName": "Development",
    "shortDescription": "共通開発 flow、skill、MCP server",
    "longDescription": "Codex CLI と Claude Code で実装から Draft PR と振り返りまでの開発フロー、Git/GitHub の利用 skill、AWS、Terraform、GitHub の共通 MCP server を使うための開発用 plugin。",
    "developerName": "mami0tsu",
    "category": "Developer Tools",
    "capabilities": [
      "Read",
      "Interactive"
    ],
    "defaultPrompt": [
      "共通の開発 skill と tools を使う"
    ],
    "brandColor": "#2563EB",
    "screenshots": []
  }
}
